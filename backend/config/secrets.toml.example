# =============================================
# AutiStudy - Streamlit Secrets Configuration
# =============================================
# Copy this file to secrets.toml and add your API keys
# DO NOT commit secrets.toml to git!
# On Streamlit Cloud, add these in the Secrets section

# OpenAI API Key (Required for AI Tutor and TTS)
OPENAI_API_KEY = "sk-your-openai-api-key-here"

# WaveSpeed AI API Key (Required for Image Generation)
WAVESPEED_API_KEY = "your-wavespeed-api-key-here"
